@inject NavigationManager Nav

<nav class="nav">
    <div class="nav-inner">
        <a href="/" class="nav-logo">
            <div class="nav-logo-mark">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
            </div>
            TACHILL SCALES
        </a>

        <ul class="nav-links">
            <li><a href="/" class="@LinkClass("/")">Hjem</a></li>
            <li><a href="/service" class="@LinkClass("/service")">Service</a></li>
            <li><a href="/produkter" class="@LinkClass("/produkter")">Produkter</a></li>
            <li><a href="@KontaktHref" class="@KontaktClass">Kontakt i dag</a></li>
        </ul>

        <div class="nav-phone">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.09 6.09l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            +45 12345678
        </div>
    </div>
</nav>

@code {
    private string CurrentPath =>
        "/" + new Uri(Nav.Uri).AbsolutePath.Trim('/').ToLower();

    private string LinkClass(string path)
    {
        var current = CurrentPath == "/" ? "/" : CurrentPath.TrimEnd('/');
        var target = path == "/" ? "/" : path.TrimEnd('/');
        return current == target ? "active" : "";
    }

    // "Kontakt i dag" scroller ned på Home, navigerer hjem+anker på andre sider
    private string KontaktHref =>
        CurrentPath == "/" ? "#kontakt" : "/#kontakt";

    private string KontaktClass => "";
}
