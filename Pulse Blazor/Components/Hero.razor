<section class="hero" id="hjem">
    <div class="hero-inner">

        <!-- Left: Text -->
        <div>
            <div class="hero-chip">
                <div class="hero-chip-dot">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                    </svg>
                </div>
                Tahcill Scales — Markedsføring & AI-Teknologi
            </div>

            <h1 class="hero-title">
                Du eksisterer ikke<br />
                uden markedsføring.
            </h1>

            <p class="hero-desc">
                Markedsføring er ikke en udgiftspost. Det er forudsætningen for alt andet. Vi er partneren der sikrer at din virksomhed altid er synlig, relevant og husket — understøttet af intelligent AI-teknologi.
            </p>

            <div class="hero-actions">
                <a href="#kontakt" class="btn-green">
                    Book en strategisamtale
                </a>
                <a href="/service" class="btn-outline">Se vores ydelser →</a>
            </div>

            <div class="hero-proof">
                <span>140+ virksomheder har valgt os som deres vækstpartner</span>
            </div>
        </div>

        <!-- Right: Signal SVG Graphic -->
        <svg class="hero-signal-art" width="480" height="480" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="dotgrid" width="24" height="24" patternUnits="userSpaceOnUse">
                    <circle cx="1" cy="1" r="1" fill="var(--surface-3)"/>
                </pattern>
            </defs>

            <!-- Dot grid background -->
            <rect width="480" height="480" fill="url(#dotgrid)" opacity="0.6"/>

            <!-- Central point -->
            <circle cx="240" cy="240" r="4" fill="var(--accent)"/>

            <!-- Expanding broadcast arcs -->
            <path d="M 240 240 m -50 0 a 50 50 0 0 1 100 0" stroke="var(--accent)" stroke-width="1" fill="none" opacity="0.9"/>
            <path d="M 240 240 m -100 0 a 100 100 0 0 1 200 0" stroke="var(--accent)" stroke-width="1" fill="none" opacity="0.7"/>
            <path d="M 240 240 m -160 0 a 160 160 0 0 1 320 0" stroke="var(--accent)" stroke-width="1" fill="none" opacity="0.5"/>
            <path d="M 240 240 m -220 0 a 220 220 0 0 1 440 0" stroke="var(--accent)" stroke-width="1" fill="none" opacity="0.3"/>

            <!-- Radiating signal rays -->
            <line x1="240" y1="240" x2="380" y2="100" stroke="var(--line)" stroke-width="1"/>
            <line x1="240" y1="240" x2="400" y2="160" stroke="var(--line)" stroke-width="1"/>
            <line x1="240" y1="240" x2="410" y2="240" stroke="var(--line)" stroke-width="1"/>
            <line x1="240" y1="240" x2="380" y2="360" stroke="var(--line)" stroke-width="1"/>
            <line x1="240" y1="240" x2="280" y2="410" stroke="var(--line)" stroke-width="1"/>

            <!-- Reception nodes -->
            <circle cx="380" cy="100" r="3" fill="none" stroke="var(--accent-mid)" stroke-width="1"/>
            <circle cx="400" cy="160" r="3" fill="none" stroke="var(--accent-mid)" stroke-width="1"/>
            <circle cx="410" cy="240" r="3" fill="none" stroke="var(--accent-mid)" stroke-width="1"/>

            <!-- Decorative line -->
            <line x1="120" y1="360" x2="360" y2="360" stroke="var(--line)" stroke-width="1"/>

            <!-- Labels -->
            <text x="360" y="385" font-family="'Plus Jakarta Sans', sans-serif" font-size="9" fill="var(--ink-4)" letter-spacing="0.1em">SIGNAL</text>
            <text x="360" y="398" font-family="'Plus Jakarta Sans', sans-serif" font-size="9" fill="var(--ink-4)" letter-spacing="0.1em">STYRKE</text>
        </svg>

    </div>
</section>
