<!-- Pulse AI Feature Section -->
<section class="pulse-ai-feature">
    <div class="pulse-ai-inner">
        <div class="pulse-ai-content">
            <div class="pulse-ai-eyebrow">Pulse AI — Vores flagship-produkt</div>
            <h2 class="pulse-ai-title">
                Fremtiden for kundeservice er her.
            </h2>
            <p class="pulse-ai-body">
                Pulse AI er intelligent AI-teknologi der besvarer dine kunders spørgsmål øjeblikkeligt — på alle kanaler, 24 timer i døgnet, 365 dage om året. Resultatet er ikke blot hurtigere service. Det er en fundamental ændring i, hvordan din virksomhed skalerer.
            </p>

            <div class="pulse-ai-features">
                <div class="pulse-ai-feature-item">
                    <div class="pulse-ai-feature-icon"></div>
                    <div class="pulse-ai-feature-text">
                        <strong>Automatisk svar på 80% af henvendelser</strong> — uden menneskelig indgriben, uden ventetid.
                    </div>
                </div>
                <div class="pulse-ai-feature-item">
                    <div class="pulse-ai-feature-icon"></div>
                    <div class="pulse-ai-feature-text">
                        <strong>Under 2 sekunders svartid, altid</strong> — Pulse AI svarer lige så hurtigt som dine bedste kundeservicemitarbejdere.
                    </div>
                </div>
                <div class="pulse-ai-feature-item">
                    <div class="pulse-ai-feature-icon"></div>
                    <div class="pulse-ai-feature-text">
                        <strong>Lavere supportomkostninger fra dag 30</strong> — Du sparer betydeligt på løn, træning og drift.
                    </div>
                </div>
            </div>

            <a href="#kontakt" class="btn-green">
                Kom i gang med Pulse AI
            </a>
            <a href="/produkter" class="service-link" style="margin-left: 1.5rem;">
                Se alle funktioner →
            </a>
        </div>

        <!-- Right: Neural Network SVG -->
        <svg class="ai-graphic" width="420" height="380" viewBox="0 0 420 380" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="aigrid" width="20" height="20" patternUnits="userSpaceOnUse">
                    <circle cx="1" cy="1" r="0.75" fill="var(--surface-3)"/>
                </pattern>
            </defs>

            <!-- Grid background -->
            <rect width="420" height="380" fill="url(#aigrid)"/>

            <!-- Layer 1 (Input nodes) -->
            <circle cx="80" cy="100" r="5" stroke="var(--ink-4)" stroke-width="1" fill="var(--surface)"/>
            <circle cx="80" cy="190" r="5" stroke="var(--ink-4)" stroke-width="1" fill="var(--surface)"/>
            <circle cx="80" cy="280" r="5" stroke="var(--ink-4)" stroke-width="1" fill="var(--surface)"/>

            <!-- Layer 2 (Hidden nodes) -->
            <circle cx="210" cy="130" r="5" stroke="var(--accent)" stroke-width="1.25" fill="var(--accent-lt)"/>
            <circle cx="210" cy="190" r="5" stroke="var(--accent)" stroke-width="1.25" fill="var(--accent-lt)"/>
            <circle cx="210" cy="250" r="5" stroke="var(--accent)" stroke-width="1.25" fill="var(--accent-lt)"/>

            <!-- Layer 3 (Output node) -->
            <circle cx="340" cy="160" r="7" stroke="var(--accent)" stroke-width="1.5" fill="var(--accent)"/>
            <circle cx="340" cy="250" r="5" stroke="var(--ink-4)" stroke-width="1" fill="var(--surface)"/>

            <!-- Connections L1 to L2 -->
            <line x1="85" y1="100" x2="205" y2="130" stroke="var(--line)" stroke-width="0.75"/>
            <line x1="85" y1="100" x2="205" y2="190" stroke="var(--line)" stroke-width="0.75"/>
            <line x1="85" y1="190" x2="205" y2="130" stroke="var(--line)" stroke-width="0.75"/>
            <line x1="85" y1="190" x2="205" y2="190" stroke="var(--line)" stroke-width="0.75"/>
            <line x1="85" y1="190" x2="205" y2="250" stroke="var(--line)" stroke-width="0.75"/>
            <line x1="85" y1="280" x2="205" y2="190" stroke="var(--line)" stroke-width="0.75"/>
            <line x1="85" y1="280" x2="205" y2="250" stroke="var(--line)" stroke-width="0.75"/>

            <!-- Connections L2 to L3 (active paths) -->
            <line x1="215" y1="130" x2="333" y2="160" stroke="var(--accent-mid)" stroke-width="1"/>
            <line x1="215" y1="190" x2="333" y2="160" stroke="var(--accent-mid)" stroke-width="1"/>
            <line x1="215" y1="190" x2="333" y2="250" stroke="var(--line)" stroke-width="0.75"/>
            <line x1="215" y1="250" x2="333" y2="160" stroke="var(--accent-mid)" stroke-width="1" opacity="0.6"/>
            <line x1="215" y1="250" x2="333" y2="250" stroke="var(--line)" stroke-width="0.75"/>

            <!-- Output label -->
            <text x="334" y="168" font-family="'Plus Jakarta Sans', sans-serif" font-size="10" fill="white" font-weight="700">AI</text>

            <!-- Bottom annotation -->
            <line x1="60" y1="340" x2="360" y2="340" stroke="var(--line)" stroke-width="1"/>
            <text x="60" y="358" font-family="'Plus Jakarta Sans', sans-serif" font-size="8" fill="var(--ink-4)" letter-spacing="0.15em">PULSE AI — NEURAL PROCESSING</text>
        </svg>
    </div>
</section>
