<section class="use-cases" id="use-cases">
    <div class="section-inner">
        <div class="section-header">
            <span class="section-eyebrow">Use Cases</span>
            <h2 class="section-title">Built for every industry</h2>
            <p class="section-desc">
                Pulse AI adapts to your specific industry needs, compliance requirements,
                and customer expectations.
            </p>
        </div>

        <div class="use-cases-grid">
            @foreach (var uc in _useCases)
            {
                <div class="use-case-card">
                    <div class="use-case-icon-row">
                        <div class="use-case-icon">
                            @((MarkupString)uc.IconSvg)
                        </div>
                        <span class="use-case-label">@uc.Label</span>
                    </div>
                    <h3 class="use-case-title">@uc.Title</h3>
                    <p class="use-case-desc">@uc.Description</p>
                    <span class="use-case-stat">@uc.Stat</span>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record UseCase(string IconSvg, string Label, string Title, string Description, string Stat);

    private readonly UseCase[] _useCases =
    {
        new(
