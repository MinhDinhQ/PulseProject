<section class="features" id="features">
    <div class="section-inner">
        <div class="section-header">
            <span class="section-eyebrow">Features</span>
            <h2 class="section-title">Everything you need to automate support</h2>
            <p class="section-desc">
                Pulse AI combines advanced NLP, seamless integrations, and intelligent routing
                to deliver exceptional customer experiences at scale.
            </p>
        </div>

        <div class="features-grid">
            @foreach (var feature in _features)
            {
                <div class="feature-card">
                    <div class="feature-icon">
                        @((MarkupString)feature.IconSvg)
                    </div>
                    <h3 class="feature-title">@feature.Title</h3>
                    <p class="feature-desc">@feature.Description</p>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record Feature(string IconSvg, string Title, string Description);

    private readonly Feature[] _features =
    {
        new(
            """<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>""",
            "Intelligent Conversations",
            "Context-aware AI that understands nuance, remembers conversation history, and responds naturally to complex customer inquiries."
        ),
        new(
            """<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>""",
            "Real-Time Analytics",
            "Deep insights into customer sentiment, resolution rates, and agent performance to continuously improve your support operations."
        ),
        new(
            """<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>""",
            "Smart Scheduling",
            "Automatically route, prioritize, and schedule customer interactions based on urgency, topic, and agent expertise."
        ),
        new(
            """<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>""",
            "Instant Resolution",
            "Resolve up to 80% of customer inquiries automatically with intelligent responses powered by your knowledge base."
        ),
        new(
            """<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>""",
            "Omnichannel Support",
            "Deliver consistent experiences across email, chat, social media, and phone — all managed from a single intelligent platform."
        ),
        new(
            """<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>""",
            "Enterprise Security",
            "Bank-grade encryption, GDPR compliance, SSO integration, and comprehensive audit trails to keep your data safe."
        ),
    };
}
