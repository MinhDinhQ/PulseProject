<section class="section-wrap">
    <div class="section-inner">
        <div class="section-header">
            <div class="section-eyebrow">Kundeanmeldelser</div>
            <h2 class="section-title">Hvad vores kunder siger</h2>
        </div>

        <div class="testimonials-track">
            <div class="testimonials-slider" style="transform: translateX(-@(_current * _cardWidth)%)">
                @foreach (var t in _testimonials)
                {
                    <div class="testimonial-card">
                        <div class="testimonial-quote-mark">"</div>
                        <p class="testimonial-quote">@t.Quote</p>
                        <div class="testimonial-author">
                            <div class="testimonial-name">@t.Name</div>
                            <div class="testimonial-role">@t.Role</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="testimonials-controls">
            <button class="ctrl-btn" @onclick="Prev" disabled="@(_current == 0)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m15 18-6-6 6-6"/>
                </svg>
            </button>

            <div class="ctrl-dots">
                @for (int i = 0; i <= MaxPage; i++)
                {
                    var idx = i;
                    <div class="ctrl-dot @(idx == _current ? "active" : "")" @onclick="() => GoTo(idx)"></div>
                }
            </div>

            <button class="ctrl-btn" @onclick="Next" disabled="@(_current == MaxPage)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m9 18 6-6-6-6"/>
                </svg>
            </button>
        </div>
    </div>
</section>

@code {
    private int _current = 0;
    private const double _cardWidth = 100;
    private int MaxPage => _testimonials.Length - 1;

    private record Testimonial(string Quote, string Name, string Role, string Initials);

    private readonly Testimonial[] _testimonials =
    {
        new("Vi valgte Tahcill Scales fordi de forstår forretning, ikke blot annoncer. Vores Google Ads ROI steg med 280% på tre måneder. Den slags resultater taler for sig selv.",
            "Lars Andersen — CEO, Salling Group", "CEO, Salling Group", "LA"),
        new("Vores nye hjemmeside konverterer langt bedre end den gamle. Projektet blev leveret til tiden, inden for budget og med et design der faktisk afspejler vores brand.",
            "Maria Jensen — Marketing Director, Bilka", "Marketing Director, Bilka", "MJ"),
        new("Pulse AI har frigivet vores supportteam fra de gentagne spørgsmål. 60% lavere supportomkostninger. Det er ikke en small sag for en virksomhed i vores størrelse.",
            "Thomas Nielsen — Operations Manager, Jysk", "Operations Manager, Jysk", "TN"),
    };

    private void Prev() { if (_current > 0) _current--; }
    private void Next() { if (_current < MaxPage) _current++; }
    private void GoTo(int idx) { _current = idx; }
}
