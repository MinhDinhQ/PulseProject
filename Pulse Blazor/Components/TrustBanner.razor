<div class="trust-banner">
    <p class="trust-banner-label">Vores kunder</p>
    <div class="trust-track-wrapper">
        <div class="trust-track">
            @foreach (var item in _items)
            {
                <div class="trust-item">
                    <img src="images/logos/@(item.ToLower().Replace(" ", "-")).png" alt="@item" class="trust-logo" />
                </div>
            }
            @* Duplicate for seamless loop *@
            @foreach (var item in _items)
            {
                <div class="trust-item">
                    <img src="images/logos/@(item.ToLower().Replace(" ", "-")).png" alt="@item" class="trust-logo" />
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly string[] _items =
    {
        "Salling Group",
        "Bilka",
        "McDonald's",
        "Jysk",
        "Velo",
        "State Energy Drink",
    };
}
