@page "/om-os"

<PageTitle>Om os — Tahcill Scales</PageTitle>

<Navigation />

<!-- ══ HERO ══ -->
<section class="oo-hero-modern">
    <div class="section-inner">
        <div class="oo-hero-modern-content">
            <div class="oo-hero-modern-badge">OM OS</div>
            <h1 class="oo-hero-modern-title">Vi bygger<br/><span class="accent-text">vækst</span> som virker.</h1>
            <p class="oo-hero-modern-sub">Ikke et bureau. En partner. Vi kombinerer strategi, data, og ekspertise for at transformere din forretning fra tag-til-til dag.</p>
            <div class="oo-hero-modern-accent"></div>
        </div>
    </div>
</section>

<!-- ══ STATS ══ -->
<section class="oo-stats-modern">
    <div class="section-inner">
        <div class="oo-stats-modern-grid">
            <div class="oo-stat-modern">
                <div class="oo-stat-modern-icon">📈</div>
                <div class="oo-stat-modern-val">140+</div>
                <div class="oo-stat-modern-lbl">Virksomheder</div>
            </div>
            <div class="oo-stat-modern">
                <div class="oo-stat-modern-icon">🎯</div>
                <div class="oo-stat-modern-val">340%</div>
                <div class="oo-stat-modern-lbl">ROI gennemsnitlig</div>
            </div>
            <div class="oo-stat-modern">
                <div class="oo-stat-modern-icon">⚡</div>
                <div class="oo-stat-modern-val">3+</div>
                <div class="oo-stat-modern-lbl">År erfaring</div>
            </div>
            <div class="oo-stat-modern">
                <div class="oo-stat-modern-icon">🤖</div>
                <div class="oo-stat-modern-val">24/7</div>
                <div class="oo-stat-modern-lbl">AI support</div>
            </div>
        </div>
    </div>
</section>

<!-- ══ VALUES ══ -->
<section class="oo-values-modern">
    <div class="section-inner">
        <div class="oo-values-modern-header">
            <h2 class="oo-values-modern-title">Vores værdier</h2>
            <p class="oo-values-modern-subtitle">Hvad der driver os hver dag</p>
        </div>
        <div class="oo-values-modern-grid">
            <div class="oo-value-modern-card">
                <div class="oo-value-modern-icon">💬</div>
                <h3 class="oo-value-modern-title">Ærlighed</h3>
                <p class="oo-value-modern-text">Vi siger tingene som de er. Også når det ikke er det du vil høre.</p>
            </div>

            <div class="oo-value-modern-card">
                <div class="oo-value-modern-icon">📊</div>
                <h3 class="oo-value-modern-title">Data-drevet</h3>
                <p class="oo-value-modern-text">Hver beslutning baseres på tal og data, ikke gætværk.</p>
            </div>

            <div class="oo-value-modern-card">
                <div class="oo-value-modern-icon">🎯</div>
                <h3 class="oo-value-modern-title">Ejerskab</h3>
                <p class="oo-value-modern-text">Vi tager ansvar og finder løsninger. Ingen undskyldninger.</p>
            </div>

            <div class="oo-value-modern-card">
                <div class="oo-value-modern-icon">🚀</div>
                <h3 class="oo-value-modern-title">Ambition</h3>
                <p class="oo-value-modern-text">Vi sætter barren højt. Middelmådige resultater accepterer vi ikke.</p>
            </div>

            <div class="oo-value-modern-card">
                <div class="oo-value-modern-icon">🔍</div>
                <h3 class="oo-value-modern-title">Transparens</h3>
                <p class="oo-value-modern-text">Du ser præcis hvad vi gør og hvilke resultater det giver.</p>
            </div>

            <div class="oo-value-modern-card">
                <div class="oo-value-modern-icon">🤝</div>
                <h3 class="oo-value-modern-title">Partnerskab</h3>
                <p class="oo-value-modern-text">Din success er vores success. Vi bygger langsigtede relationer.</p>
            </div>
        </div>
    </div>
</section>

<!-- ══ CTA ══ -->
<section class="oo-cta">
    <div class="section-inner">
        <div class="oo-cta-inner" data-animate="fade-up">
            <h2 class="oo-cta-title">Klar til at blive set?</h2>
            <p class="oo-cta-sub">Book en uforpligtende samtale og find ud af om vi er det rette match.</p>
            <a href="/#kontakt" class="btn-white">Book en gratis samtale</a>
        </div>
    </div>
</section>

<PulseFooter />
