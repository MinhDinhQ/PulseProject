@page "/kontakt"

<PageTitle>Kontakt — Tahcill Scales</PageTitle>

<Navigation />

<!-- Hero Section -->
<section class="contact-hero">
    <div class="section-inner">
        <div class="contact-hero-content" data-animate="fade-up">
            <div class="contact-hero-badge">Lad os arbejde sammen</div>
            <h1 class="contact-hero-title">Hey! Tell us all<br/><span class="accent-text">the things</span></h1>
            <p class="contact-hero-sub">Vi svarer inden for 24 timer — uden salgspres, kun ærlighed.</p>
        </div>
    </div>
</section>

<!-- Main Contact Section -->
<section class="contact-main">
    <div class="section-inner">
        <div class="contact-wrapper">

            <!-- Left: Contact Info -->
            <div class="contact-info-block" data-animate="fade-up">
                <div class="contact-info-header">
                    <h2 class="contact-info-title">Kontakt os direkte</h2>
                    <p class="contact-info-sub">Eller udfyld formularen og vi vender tilbage hurtigt.</p>
                </div>

                <div class="contact-details">
                    <a href="tel:+4512345678" class="contact-detail-item">
                        <div class="contact-detail-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </div>
                        <div>
                            <div class="contact-detail-label">Ring til os</div>
                            <div class="contact-detail-value">+45 12 34 56 78</div>
                        </div>
                    </a>

                    <a href="mailto:hej@tahcillscales.dk" class="contact-detail-item">
                        <div class="contact-detail-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </div>
                        <div>
                            <div class="contact-detail-label">Skriv til os</div>
                            <div class="contact-detail-value">hej@tahcillscales.dk</div>
                        </div>
                    </a>

                    <div class="contact-detail-item">
                        <div class="contact-detail-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                            </svg>
                        </div>
                        <div>
                            <div class="contact-detail-label">Besøg os</div>
                            <div class="contact-detail-value">København, Danmark</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Form -->
            <div class="contact-form-block" data-animate="fade-left" data-delay="120">
                @if (_sent)
                {
                    <div class="contact-success">
                        <div class="contact-success-icon">✓</div>
                        <h3 class="contact-success-title">Besked modtaget!</h3>
                        <p class="contact-success-sub">Tak fordi du skrev til os. Vi vender tilbage inden for 24 timer.</p>
                    </div>
                }
                else
                {
                    <form class="contact-form" @onsubmit="Submit" @onsubmit:preventDefault>
                        <div class="contact-form-row">
                            <div class="contact-form-field">
                                <label for="name">Dit navn</label>
                                <input type="text" id="name" placeholder="Dit fulde navn" @bind="_name" required />
                            </div>
                            <div class="contact-form-field">
                                <label for="email">Email adresse</label>
                                <input type="email" id="email" placeholder="din@email.dk" @bind="_email" required />
                            </div>
                        </div>

                        <div class="contact-form-row">
                            <div class="contact-form-field">
                                <label for="company">Virksomhed</label>
                                <input type="text" id="company" placeholder="Virksomhedens navn" @bind="_company" />
                            </div>
                            <div class="contact-form-field">
                                <label for="phone">Telefon</label>
                                <input type="tel" id="phone" placeholder="+45 00 00 00 00" @bind="_phone" />
                            </div>
                        </div>

                        <div class="contact-form-field full">
                            <label for="message">Hvad kan vi hjælpe med?</label>
                            <textarea id="message" placeholder="Fortæl kort om din virksomhed og hvad du ønsker hjælp til..." @bind="_message" rows="5" required></textarea>
                        </div>

                        <button type="submit" class="contact-submit">
                            Send besked
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                            </svg>
                        </button>
                    </form>
                }
            </div>

        </div>
    </div>
</section>

<PulseFooter />

<style>
    /* Hero Section */
    .contact-hero {
        padding: 80px 0 60px;
        background: linear-gradient(135deg, #ffffff 0%, #f9f9f9 100%);
        border-bottom: 1px solid #e8e8e8;
    }

    .contact-hero-content {
        text-align: center;
        max-width: 700px;
        margin: 0 auto;
    }

    .contact-hero-badge {
        display: inline-block;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #2563eb;
        margin-bottom: 16px;
        padding: 6px 12px;
        background: rgba(37, 99, 235, 0.1);
        border-radius: 20px;
    }

    .contact-hero-title {
        font-size: clamp(40px, 6vw, 64px);
        font-weight: 800;
        line-height: 1.1;
        margin: 16px 0 24px;
        color: #000;
    }

    .contact-hero-title .accent-text {
        background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .contact-hero-sub {
        font-size: 18px;
        color: #666;
        line-height: 1.6;
    }

    /* Main Contact Section */
    .contact-main {
        padding: 100px 0;
    }

    .contact-wrapper {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: flex-start;
    }

    @@media (max-width: 768px) {
        .contact-wrapper {
            grid-template-columns: 1fr;
            gap: 60px;
        }
    }

    /* Contact Info Block */
    .contact-info-block {
        padding-right: 40px;
    }

    .contact-info-header {
        margin-bottom: 48px;
    }

    .contact-info-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 12px;
        color: #000;
    }

    .contact-info-sub {
        font-size: 16px;
        color: #666;
        line-height: 1.6;
    }

    .contact-details {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .contact-detail-item {
        display: flex;
        gap: 16px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        padding: 16px;
        border-radius: 12px;
        margin: -16px;
    }

    .contact-detail-item:hover {
        background: rgba(37, 99, 235, 0.05);
        transform: translateX(8px);
    }

    .contact-detail-icon {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(37, 99, 235, 0.1);
        border-radius: 8px;
        color: #2563eb;
    }

    .contact-detail-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #999;
        margin-bottom: 4px;
    }

    .contact-detail-value {
        font-size: 16px;
        font-weight: 600;
        color: #000;
    }

    /* Contact Form Block */
    .contact-form-block {
        background: #f9f9f9;
        padding: 48px 40px;
        border-radius: 16px;
        border: 1px solid #e8e8e8;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .contact-form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .contact-form-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .contact-form-field.full {
        grid-column: 1 / -1;
    }

    .contact-form-field label {
        font-size: 14px;
        font-weight: 600;
        color: #000;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .contact-form-field input,
    .contact-form-field textarea {
        padding: 12px 16px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 16px;
        font-family: inherit;
        transition: all 0.3s ease;
        background: #fff;
        color: #000;
    }

    .contact-form-field input:focus,
    .contact-form-field textarea:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .contact-form-field textarea {
        resize: vertical;
    }

    .contact-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 32px;
        background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 8px;
    }

    .contact-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(37, 99, 235, 0.3);
    }

    .contact-submit:active {
        transform: translateY(0);
    }

    /* Success Message */
    .contact-success {
        text-align: center;
        padding: 40px 20px;
    }

    .contact-success-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 24px;
        background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 32px;
        font-weight: 700;
    }

    .contact-success-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 8px;
        color: #000;
    }

    .contact-success-sub {
        font-size: 16px;
        color: #666;
        line-height: 1.6;
    }

    @@media (max-width: 768px) {
        .contact-hero {
            padding: 60px 0 40px;
        }

        .contact-main {
            padding: 60px 0;
        }

        .contact-info-block {
            padding-right: 0;
        }

        .contact-form-block {
            padding: 32px 24px;
        }

        .contact-form-row {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>

@code {
    private string _name = "", _company = "", _email = "", _phone = "", _message = "";
    private bool _sent = false;

    private void Submit()
    {
        if (!string.IsNullOrWhiteSpace(_name) && !string.IsNullOrWhiteSpace(_email) && !string.IsNullOrWhiteSpace(_message))
        {
            _sent = true;
        }
    }
}