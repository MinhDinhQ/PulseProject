<style>
    .hs-hero {
        padding: 60px 0 40px;
    }

    .hs-hero-inner {
        text-align: center;
    }

    .hs-hero-eyebrow {
        display: inline-block;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #22c55e;
        margin-bottom: 12px;
        padding: 6px 12px;
        background: rgba(34, 197, 94, 0.1);
        border-radius: 20px;
    }

    .hs-hero-title {
        font-size: clamp(40px, 6vw, 56px);
        font-weight: 800;
        line-height: 1.2;
        margin: 16px 0 20px;
        color: #000;
    }

    .hs-hero-sub {
        font-size: 16px;
        color: #666;
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
    }

    .hs-hero-deco {
        margin-top: 40px;
        display: flex;
        justify-content: center;
        gap: 12px;
        height: 200px;
    }

    .hs-deco-line {
        width: 2px;
        background: linear-gradient(180deg, transparent 0%, #e8e8e8 50%, transparent 100%);
    }

    .hs-section {
        padding: 80px 0;
    }

    .hs-inner {
        max-width: 900px;
        margin: 0 auto;
    }

    .hs-card {
        padding: 40px;
        border-radius: 12px;
        animation: fade-up 0.6s ease;
    }

    .hs-card[data-delay="100"] {
        animation-delay: 100ms;
    }

    .hs-card-num {
        font-size: 36px;
        font-weight: 800;
        color: #22c55e;
        margin-bottom: 12px;
    }

    .hs-card-body {
        margin-top: 24px;
    }

    .hs-card-eyebrow {
        display: inline-block;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #999;
        margin-bottom: 12px;
    }

    .hs-card-title {
        font-size: 28px;
        font-weight: 700;
        margin: 12px 0 16px;
        color: #000;
        line-height: 1.3;
    }

    .hs-card-desc {
        font-size: 15px;
        color: #666;
        line-height: 1.7;
        margin-bottom: 32px;
    }

    .hs-features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 24px;
    }

    .hs-feature {
        display: flex;
        gap: 12px;
        padding: 16px;
        background: rgba(34, 197, 94, 0.05);
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .hs-feature:hover {
        background: rgba(34, 197, 94, 0.1);
        transform: translateY(-2px);
    }

    .hs-feature-icon {
        color: #22c55e;
        font-size: 16px;
        flex-shrink: 0;
    }

    .hs-feature-name {
        font-size: 14px;
        font-weight: 600;
        color: #000;
        margin-bottom: 4px;
    }

    .hs-feature-desc {
        font-size: 13px;
        color: #666;
    }

    .hs-divider {
        height: 1px;
        background: #e8e8e8;
        margin: 60px 0;
    }

    @@media (max-width: 768px) {
        .hs-hero {
            padding: 40px 0 30px;
        }

        .hs-section {
            padding: 60px 0;
        }

        .hs-card {
            padding: 24px;
        }

        .hs-card-title {
            font-size: 22px;
        }

        .hs-features {
            grid-template-columns: 1fr;
        }
    }
</style>
