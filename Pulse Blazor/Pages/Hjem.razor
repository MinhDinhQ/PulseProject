@page "/"

<PageTitle>Tahcill Scales — Digital Growth & AI</PageTitle>

<Navigation />

<!-- Hero -->
<section class="hjem-hero">
    <div class="hjem-hero-bg"></div>
    <div class="section-inner">
        <div class="hjem-hero-content" data-animate="fade-up">
            <div class="hjem-hero-label">Digital Growth Agency</div>
            <h1 class="hjem-hero-title">
                Growth<br/>That<br/>Matters
            </h1>
            <p class="hjem-hero-desc">Strategy, design, and AI working in perfect harmony. We don't just run campaigns—we build business momentum.</p>
            <div class="hjem-hero-cta">
                <a href="/kontakt" class="hjem-btn-primary">Get Started</a>
                <a href="#services" class="hjem-btn-secondary">Explore Services</a>
            </div>
        </div>
    </div>
</section>

<!-- Services Grid -->
<section class="hjem-services" id="services">
    <div class="section-inner">
        <div class="hjem-services-header" data-animate="fade-up">
            <h2 class="hjem-section-title">What We Do</h2>
            <p class="hjem-section-desc">Three specialties. One purpose: accelerating your growth.</p>
        </div>

        <div class="hjem-services-grid">
            <a href="/paid-ads" class="hjem-service-block" data-animate="fade-up" data-delay="0">
                <div class="hjem-service-bg" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.08) 0%, rgba(79, 70, 229, 0.02) 100%);"></div>
                <div class="hjem-service-content">
                    <div class="hjem-service-icon">01</div>
                    <h3>Paid Ads</h3>
                    <p>Google & Meta campaigns that drive qualified leads and sustainable growth.</p>
                    <span class="hjem-service-link">Learn More →</span>
                </div>
            </a>

            <a href="/hjemmesider" class="hjem-service-block" data-animate="fade-up" data-delay="100">
                <div class="hjem-service-bg" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.04) 0%, rgba(79, 70, 229, 0.01) 100%);"></div>
                <div class="hjem-service-content">
                    <div class="hjem-service-icon">02</div>
                    <h3>Websites</h3>
                    <p>SEO-optimized, conversion-focused websites that turn visitors into customers.</p>
                    <span class="hjem-service-link">Learn More →</span>
                </div>
            </a>

            <a href="/pulse-ai" class="hjem-service-block" data-animate="fade-up" data-delay="200">
                <div class="hjem-service-bg" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.06) 0%, rgba(79, 70, 229, 0.015) 100%);"></div>
                <div class="hjem-service-content">
                    <div class="hjem-service-icon">03</div>
                    <h3>Pulse AI</h3>
                    <p>24/7 AI assistant that qualifies leads while you sleep. Always on, always learning.</p>
                    <span class="hjem-service-link">Learn More →</span>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- Why Us -->
<section class="hjem-why-us">
    <div class="section-inner">
        <div class="hjem-why-header" data-animate="fade-up">
            <h2 class="hjem-section-title">Why Choose Tahcill Scales</h2>
            <p class="hjem-section-desc">Built on principles that actually matter</p>
        </div>

        <div class="hjem-why-grid">
            <div class="hjem-why-item" data-animate="fade-up" data-delay="0">
                <div class="hjem-why-number">01</div>
                <h3>Data-Driven</h3>
                <p>Every decision backed by numbers. No guesswork, only results you can measure.</p>
            </div>
            <div class="hjem-why-item" data-animate="fade-up" data-delay="100">
                <div class="hjem-why-number">02</div>
                <h3>Ownership</h3>
                <p>We take full responsibility for your success. Your goals become our mission.</p>
            </div>
            <div class="hjem-why-item" data-animate="fade-up" data-delay="200">
                <div class="hjem-why-number">03</div>
                <h3>Honesty</h3>
                <p>Direct conversations. No fluff. We tell you what you need to hear.</p>
            </div>
            <div class="hjem-why-item" data-animate="fade-up" data-delay="300">
                <div class="hjem-why-number">04</div>
                <h3>Excellence</h3>
                <p>We set the bar high. Mediocre results simply aren't acceptable.</p>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="hjem-stats">
    <div class="section-inner">
        <div class="hjem-stats-grid">
            <div class="hjem-stat-card" data-animate="fade-up" data-delay="0">
                <div class="hjem-stat-value">140+</div>
                <div class="hjem-stat-label">Companies Grown</div>
            </div>
            <div class="hjem-stat-card" data-animate="fade-up" data-delay="100">
                <div class="hjem-stat-value">340%</div>
                <div class="hjem-stat-label">Average ROI</div>
            </div>
            <div class="hjem-stat-card" data-animate="fade-up" data-delay="200">
                <div class="hjem-stat-value">94%</div>
                <div class="hjem-stat-label">Retention Rate</div>
            </div>
            <div class="hjem-stat-card" data-animate="fade-up" data-delay="300">
                <div class="hjem-stat-value">3+</div>
                <div class="hjem-stat-label">Years Expertise</div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials -->
<Testimonials />

<!-- Final CTA -->
<section class="hjem-final-cta">
    <div class="section-inner">
        <div class="hjem-cta-content" data-animate="fade-up">
            <h2 class="hjem-cta-title">Ready to grow?</h2>
            <p class="hjem-cta-desc">Let's talk about your goals and how we can help you achieve them.</p>
            <a href="/kontakt" class="hjem-btn-primary hjem-btn-large">Schedule a Call</a>
        </div>
    </div>
</section>

<PulseFooter />

